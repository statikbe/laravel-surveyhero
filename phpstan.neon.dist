parameters:
    level: 4
    paths:
        - src
        - config
        - database
    tmpDir: build/phpstan
    checkOctaneCompatibility: true
    checkModelProperties: true
    ignoreErrors:
        # This package's models are host-app-overridable (resolved via SurveyheroRegistrar /
        # config), and its public API is expressed through *Contract interfaces, so larastan
        # cannot statically resolve dynamic Eloquent columns/relations on them — nor the query
        # builder methods Eloquent forwards via __call()/__callStatic(). These are not real
        # issues in this codebase.
        - '#Access to an undefined property [a-zA-Z0-9\\_]+Contract::\$[a-zA-Z0-9\\_]+.#'
        - '#Access to an undefined property Statikbe\\Surveyhero\\Models\\[a-zA-Z]+::\$[a-zA-Z0-9\\_]+.#'
        - '#Access to an undefined property Illuminate\\Database\\Eloquent\\Model::\$[a-zA-Z0-9\\_]+.#'
        - '#Call to an undefined static method [a-zA-Z0-9\\_]+Contract::truncate\(\)#'
        - '#Call to an undefined static method [a-zA-Z0-9\\_]+Contract::updateOrCreate\(\)#'
        - '#Call to an undefined static method [a-zA-Z0-9\\_]+Contract::where\(\)#'
        - '#Call to an undefined static method [a-zA-Z0-9\\_]+Contract::whereHas\(\)#'
        - '#Call to an undefined static method [a-zA-Z0-9\\_]+Contract::create\(\)#'
        - '#Call to an undefined method [a-zA-Z0-9\\_]+Contract::save\(\)#'
        # env() in a package config file is correct; larastan's "env outside the config
        # directory" check mis-fires because the package config path differs from the
        # testbench application's config path.
        -
            identifier: larastan.noEnvCallsOutsideOfConfig
            path: config/surveyhero.php

